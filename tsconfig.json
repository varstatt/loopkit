{
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "outDir": "dist",
    "lib": ["ES2020", "DOM"]
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.mock.ts"]
}
