{
  "name": "loopkit",
  "version": "0.1.0",
  "description": "Lightweight schema-driven SVG animation engine. Define animations as data, render to DOM or string. Zero dependencies.",
  "keywords": [
    "svg",
    "animation",
    "motion",
    "lottie-alternative",
    "schema",
    "cover-art",
    "live-graphics",
    "lightweight"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/varstatt/loopkit.git"
  },
  "homepage": "https://github.com/varstatt/loopkit#readme",
  "bugs": {
    "url": "https://github.com/varstatt/loopkit/issues"
  },
  "author": "Jurij Tokarski <jurij@varstatt.com>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "test": "jest --modulePaths=src",
    "test:coverage": "jest --modulePaths=src --coverage",
    "test:watch": "jest --modulePaths=src --watch",
    "lint": "biome check src/",
    "format": "biome check --write src/",
    "prepack": "npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.0"
  }
}
